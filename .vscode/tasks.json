{
    "version": "2.0.0",
    "options": {
        "cwd": "${workspaceFolder}"
    },
    "tasks": [
        {
            "label": "cmake-configure",
            "type": "shell",
            "command": "rm -rf build && cmake",
            "args": [
                "-S", ".",
                "-B", "build"
            ],
            "group": "build",
            "detail": "Clean and configure CMake project"
        },
        {
            "label": "cmake-build",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build", "build"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "dependsOn": ["cmake-configure"],
            "problemMatcher": ["$gcc"],
            "detail": "Build the project"
        },
        {
            "label": "cmake-clean",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build", "build",
                "--target", "clean"
            ],
            "group": "build",
            "detail": "Clean build artifacts"
        },
        {
            "label": "run",
            "type": "shell",
            "command": "${workspaceFolder}/build/src/snippet_executable",
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "dependsOn": ["cmake-build"],
            "detail": "Run the executable"
        }
    ]
}
